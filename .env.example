# Lumora — environment. Copy to .env. Sane local defaults are baked in.

PORT=5800

# Session signing secret. Generate for production: openssl rand -hex 32
SESSION_SECRET=

# AES-256-GCM vault master key (hex, 32 bytes). Generated to data/.vault-key if unset.
VAULT_KEY=

# Live ICU vitals simulator tick (seconds)
VITALS_TICK_SECONDS=2

# Seed super-admin (used only when seeding an empty DB)
SEED_ADMIN_EMAIL=admin@lumora.health
SEED_ADMIN_PASSWORD=Lumora2026!
